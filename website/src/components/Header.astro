---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <button
      id="yr-sidebar-toggle"
      class="yr-hamburger"
      type="button"
      aria-label="Toggle sidebar"
      aria-expanded="true"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          d="M2 4.5h14M2 9h14M2 13.5h14"
        />
      </svg>
    </button>
    <SiteTitle {...Astro.props} />
  </div>

  <div class="sl-flex search-wrapper print:hidden">
    <Search {...Astro.props} />
  </div>

  <div class="sl-hidden md:sl-flex right-group print:hidden">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<script>
  function initSidebarToggle() {
    const btn = document.getElementById('yr-sidebar-toggle');
    if (!btn) return;
    const html = document.documentElement;
    const CLOSED = 'yr-sidebar-closed';

    const saved = localStorage.getItem('yr-sidebar');
    if (saved === 'closed') {
      html.classList.add(CLOSED);
      btn.setAttribute('aria-expanded', 'false');
    } else {
      btn.setAttribute('aria-expanded', 'true');
    }

    btn.addEventListener('click', () => {
      const closed = html.classList.toggle(CLOSED);
      btn.setAttribute('aria-expanded', String(!closed));
      localStorage.setItem('yr-sidebar', closed ? 'closed' : 'open');
    });
  }

  initSidebarToggle();
  document.addEventListener('astro:page-load', initSidebarToggle);
</script>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    align-items: center;
    gap: 0.5rem;
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
  }

  /* Only show hamburger on pages that have a sidebar */
  .yr-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: none;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    padding: 0;
  }
  :global([data-has-sidebar]) .yr-hamburger {
    display: flex;
  }
  .yr-hamburger:hover {
    color: var(--sl-color-white);
    background: rgba(255, 255, 255, 0.07);
  }

  .right-group,
  .social-icons {
    gap: 1rem;
    align-items: center;
  }
  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }
    .header {
      --__sidebar-width: max(
        0rem,
        var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x)
      );
      --__main-column-fr: calc(
        (
          100% + var(--__sidebar-pad, 0rem) -
          var(--__toc-width, var(--sl-sidebar-width)) -
          (2 * var(--__toc-width, var(--sl-nav-pad-x))) -
          var(--sl-content-inline-start, 0rem) - var(--sl-content-width)
        ) / 2
      );
      display: grid;
      grid-template-columns:
        minmax(
          calc(
            var(--__sidebar-width) +
            max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))
          ),
          auto
        )
        1fr
        auto;
      align-content: center;
    }
  }
</style>
