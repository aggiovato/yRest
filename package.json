{
  "name": "@aggiovato/yrest",
  "version": "0.2.2",
  "description": "Zero-config REST API mock server powered by a YAML file",
  "keywords": [
    "yaml",
    "rest",
    "mock",
    "api",
    "cli",
    "fastify"
  ],
  "license": "MIT",
  "author": "Aggiovato",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aggiovato/yaml-rest.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "yrest": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run test:run && npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.20",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
