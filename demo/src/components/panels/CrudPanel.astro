<div class="tab-panel" id="panel-crud">
  <p class="feature-desc">
    CRUD completo generado automáticamente desde <code>db.yml</code>:
    <code>GET /api/todos</code>, <code>POST /api/todos</code>,
    <code>PATCH /api/todos/:id</code>, <code>DELETE /api/todos/:id</code>.
    Las operaciones del todo list actualizan este log.
  </p>
  <div class="api-log" id="crud-log">
    <p class="api-log-empty">Realiza una operación en el todo list...</p>
  </div>
</div>

<script>
  import { renderLog } from '../../lib/api.ts';

  window.addEventListener('yrest:api-call', (e: Event) => {
    const { method, url, status, data } = (e as CustomEvent).detail;
    renderLog('crud-log', method, url, status, data);
  });
</script>
