---
---

<div class="tab-panel" id="panel-filters">
  <p class="feature-desc">
    Filtra por campo exacto (<code>?done=true</code>), operadores
    (<code>?priority_ne=low</code>), o búsqueda full-text (<code>?_q=término</code>).
    Varios valores en el mismo campo actúan como OR.
  </p>

  <div class="ex-controls">
    <div class="ex-field">
      <span class="ex-label">done</span>
      <select class="ex-select" id="filt-done">
        <option value="">(any)</option>
        <option value="true">true</option>
        <option value="false">false</option>
      </select>
    </div>
    <div class="ex-field">
      <span class="ex-label">priority</span>
      <select class="ex-select" id="filt-priority">
        <option value="">(any)</option>
        <option value="high">high</option>
        <option value="medium">medium</option>
        <option value="low">low</option>
      </select>
    </div>
    <div class="ex-field">
      <span class="ex-label">_q (full-text)</span>
      <input class="ex-input" id="filt-q" placeholder="buscar..." style="width:150px" />
    </div>
    <button class="btn-try" id="filters-btn">Try it &rarr;</button>
  </div>

  <div class="api-log" id="filters-log">
    <p class="api-log-empty">Configura los filtros y pulsa Try it...</p>
  </div>
</div>

<script>
  import { fetchApi, renderLog } from '../../lib/api.ts';

  document.getElementById('filters-btn')!.addEventListener('click', async () => {
    const done     = (document.getElementById('filt-done')     as HTMLSelectElement).value;
    const priority = (document.getElementById('filt-priority') as HTMLSelectElement).value;
    const q        = (document.getElementById('filt-q')        as HTMLInputElement).value.trim();
    const p = new URLSearchParams();
    if (done) p.set('done', done);
    if (priority) p.set('priority', priority);
    if (q) p.set('_q', q);
    const r = await fetchApi('GET', `/todos?${p}`);
    renderLog('filters-log', 'GET', r.url, r.status, r.data);
  });
</script>
