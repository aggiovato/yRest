---
---

<div class="tab-panel" id="panel-templates">
  <p class="feature-desc">
    Interpola datos de la request en el cuerpo de la respuesta estática:
    <code>{'{{params.id}}'}</code>, <code>{'{{now}}'}</code>,
    <code>{'{{uuid}}'}</code>, <code>{'{{query.x}}'}</code>,
    <code>{'{{body.x}}'}</code>.
    El <code>uuid</code> es diferente en cada request.
  </p>

  <div class="ex-controls">
    <div class="ex-field">
      <span class="ex-label">Todo ID</span>
      <input class="ex-input" id="tmpl-id" type="number" value="1" min="1" style="width:70px" />
    </div>
    <button class="btn-try" id="templates-btn">GET /api/todos/:id/share &rarr;</button>
  </div>

  <div class="api-log" id="templates-log">
    <p class="api-log-empty">Escribe un ID y pulsa el botón...</p>
  </div>
</div>

<script>
  import { fetchApi, renderLog } from '../../lib/api.ts';

  document.getElementById('templates-btn')!.addEventListener('click', async () => {
    const id = (document.getElementById('tmpl-id') as HTMLInputElement).value;
    const r = await fetchApi('GET', `/todos/${id}/share`);
    renderLog('templates-log', 'GET', r.url, r.status, r.data);
  });
</script>
