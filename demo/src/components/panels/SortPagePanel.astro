---
---

<div class="tab-panel" id="panel-sortpage">
  <p class="feature-desc">
    Ordena con <code>?_sort=campo&amp;_order=asc|desc</code>.
    Pagina con <code>?_page=N&amp;_limit=N</code>.
    La cabecera <code>X-Total-Count</code> devuelve el total sin paginar.
  </p>

  <div class="ex-controls">
    <div class="ex-field">
      <span class="ex-label">_sort</span>
      <select class="ex-select" id="sp-sort">
        <option value="createdAt">createdAt</option>
        <option value="title">title</option>
        <option value="priority">priority</option>
      </select>
    </div>
    <div class="ex-field">
      <span class="ex-label">_order</span>
      <select class="ex-select" id="sp-order">
        <option value="desc">desc</option>
        <option value="asc">asc</option>
      </select>
    </div>
    <div class="ex-field">
      <span class="ex-label">_page</span>
      <input class="ex-input" id="sp-page" type="number" value="1" min="1" style="width:60px" />
    </div>
    <div class="ex-field">
      <span class="ex-label">_limit</span>
      <input class="ex-input" id="sp-limit" type="number" value="3" min="1" max="20" style="width:60px" />
    </div>
    <button class="btn-try" id="sortpage-btn">Try it &rarr;</button>
  </div>

  <div class="api-log" id="sortpage-log">
    <p class="api-log-empty">Configura ordenación y paginación, luego pulsa Try it...</p>
  </div>
</div>

<script>
  import { fetchApi, renderLog } from '../../lib/api.ts';

  document.getElementById('sortpage-btn')!.addEventListener('click', async () => {
    const sort  = (document.getElementById('sp-sort')  as HTMLSelectElement).value;
    const order = (document.getElementById('sp-order') as HTMLSelectElement).value;
    const page  = (document.getElementById('sp-page')  as HTMLInputElement).value;
    const limit = (document.getElementById('sp-limit') as HTMLInputElement).value;
    const p = new URLSearchParams({ _sort: sort, _order: order, _page: page, _limit: limit });

    const r = await fetchApi('GET', `/todos?${p}`);
    renderLog('sortpage-log', 'GET', r.url, r.status, r.data);

    // Append the X-Total-Count info to the response body
    if (r.total !== null) {
      const bodyEl = document.querySelector('#sortpage-log .api-log-body');
      if (bodyEl) bodyEl.textContent += `\n\n// X-Total-Count: ${r.total}`;
    }
  });
</script>
