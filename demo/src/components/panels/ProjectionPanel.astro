---
---

<div class="tab-panel" id="panel-projection">
  <p class="feature-desc">
    <code>?_fields=campo1,campo2</code> proyecta únicamente los campos solicitados
    en cada objeto de la respuesta. Útil para reducir el payload.
  </p>

  <div class="ex-controls">
    <div class="ex-field">
      <span class="ex-label">_fields</span>
      <input class="ex-input" id="proj-fields" value="id,title,done" style="width:220px" />
    </div>
    <button class="btn-try" id="projection-btn">Try it &rarr;</button>
  </div>

  <div class="api-log" id="projection-log">
    <p class="api-log-empty">Escribe los campos y pulsa Try it...</p>
  </div>
</div>

<script>
  import { fetchApi, renderLog } from '../../lib/api.ts';

  document.getElementById('projection-btn')!.addEventListener('click', async () => {
    const fields = (document.getElementById('proj-fields') as HTMLInputElement).value.trim();
    const p = new URLSearchParams({ _fields: fields, _limit: '4' });
    const r = await fetchApi('GET', `/todos?${p}`);
    renderLog('projection-log', 'GET', r.url, r.status, r.data);
  });
</script>
