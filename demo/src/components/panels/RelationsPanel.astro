---

<div class="tab-panel" id="panel-relations">
  <p class="feature-desc">
    <code>?_expand=user</code> expande el objeto padre (todo &rarr; user vía <code>userId</code>
    definido en <code>_rel</code>).
    <code>?_embed=todos</code> incrusta los hijos (user &rarr; todos).
    <code>GET /api/users/:id/todos</code> es la ruta anidada generada automáticamente.
  </p>

  <div class="btn-try-group">
    <button class="btn-try" id="rel-expand">GET /api/todos?_expand=user &rarr;</button>
    <button class="btn-try" id="rel-embed">GET /api/users/1?_embed=todos &rarr;</button>
    <button class="btn-try" id="rel-nested">GET /api/users/1/todos &rarr;</button>
  </div>

  <div class="api-log" id="relations-log">
    <p class="api-log-empty">Pulsa uno de los botones...</p>
  </div>
</div>

<script>
  import { fetchApi, renderLog } from '../../lib/api.ts';

  document.getElementById('rel-expand')!.addEventListener('click', async () => {
    const r = await fetchApi('GET', '/todos?_expand=user&_limit=3');
    renderLog('relations-log', 'GET', r.url, r.status, r.data);
  });

  document.getElementById('rel-embed')!.addEventListener('click', async () => {
    const r = await fetchApi('GET', '/users/1?_embed=todos');
    renderLog('relations-log', 'GET', r.url, r.status, r.data);
  });

  document.getElementById('rel-nested')!.addEventListener('click', async () => {
    const r = await fetchApi('GET', '/users/1/todos');
    renderLog('relations-log', 'GET', r.url, r.status, r.data);
  });
</script>
