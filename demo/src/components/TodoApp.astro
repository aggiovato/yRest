---
---

<section class="todo-section">

  <div class="todo-toolbar">
    <form class="add-form" id="add-form">
      <input class="add-input" id="add-input" placeholder="Nueva tarea..." autocomplete="off" maxlength="120" />
      <button class="btn" type="submit">+ Añadir</button>
    </form>

    <div class="toolbar-controls">
      <input class="search-input" id="search-input" placeholder="Buscar..." />

      <select id="filter-done">
        <option value="">Todas</option>
        <option value="false">Pendientes</option>
        <option value="true">Completadas</option>
      </select>

      <select id="filter-priority">
        <option value="">Prioridad</option>
        <option value="high">Alta</option>
        <option value="medium">Media</option>
        <option value="low">Baja</option>
      </select>

      <select id="sort-select">
        <option value="createdAt|desc">Más recientes</option>
        <option value="createdAt|asc">Más antiguos</option>
        <option value="priority|desc">Prioridad ↑</option>
        <option value="title|asc">A → Z</option>
      </select>

      <select id="limit-select">
        <option value="5">5 / pág</option>
        <option value="10">10 / pág</option>
      </select>
    </div>
  </div>

  <ul class="todo-list" id="todo-list">
    <li class="todo-placeholder">Conectando con yrest...</li>
  </ul>

  <div class="pagination">
    <button class="page-btn" id="prev-btn" disabled>&#8249;</button>
    <span class="page-info" id="page-info">- / -</span>
    <button class="page-btn" id="next-btn" disabled>&#8250;</button>
    <span class="page-count" id="page-count"></span>
  </div>

</section>

<style>
  .todo-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .todo-toolbar {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    align-items: center;
  }

  .add-form {
    display: flex;
    gap: 6px;
    flex: 1;
    min-width: 200px;
  }

  .add-input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    padding: 6px 10px;
    font-size: 13px;
    outline: none;
  }
  .add-input:focus { border-color: var(--blue); }
  .add-input::placeholder { color: var(--muted); }

  .toolbar-controls {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  select, .search-input {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    padding: 5px 8px;
    font-size: 12px;
    outline: none;
    cursor: pointer;
  }
  select:focus, .search-input:focus { border-color: var(--blue); }
  .search-input::placeholder { color: var(--muted); }

  /* List — item styles are in global.css (innerHTML bypass Astro scoping) */
  .todo-list { list-style: none; min-height: 200px; }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-top: 1px solid var(--border);
    background: var(--surface2);
  }

  .page-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    width: 28px;
    height: 28px;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
  }
  .page-btn:hover:not(:disabled) { border-color: var(--blue); color: var(--blue); }
  .page-btn:disabled { opacity: 0.35; cursor: not-allowed; }

  .page-info { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .page-count { margin-left: auto; font-size: 12px; color: var(--muted); }
</style>

<script>
  import { fetchApi } from '../lib/api.ts';

  const state = {
    page: 1, limit: 5, sort: 'createdAt', order: 'desc',
    search: '', done: '', priority: '', total: 0,
  };

  // Preloaded user map: id → { name, avatar }
  const users = new Map<number, { name: string; avatar: string }>();

  function esc(s: string): string {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function dispatch(method: string, url: string, status: number, data: unknown) {
    window.dispatchEvent(new CustomEvent('yrest:api-call', {
      detail: { method, url, status, data },
    }));
  }

  async function loadUsers() {
    const r = await fetchApi('GET', '/users');
    if (Array.isArray(r.data)) {
      for (const u of r.data as any[]) {
        users.set(u.id, { name: u.name, avatar: u.avatar });
      }
    }
  }

  async function loadTodos() {
    const p = new URLSearchParams({
      _page: String(state.page),
      _limit: String(state.limit),
      _sort: state.sort,
      _order: state.order,
    });
    if (state.search) p.set('_q', state.search);
    if (state.done) p.set('done', state.done);
    if (state.priority) p.set('priority', state.priority);

    const r = await fetchApi('GET', `/todos?${p}`);
    dispatch('GET', r.url, r.status, r.data);
    if (r.total !== null) state.total = parseInt(r.total);
    renderList(r.data as unknown[]);
    renderPagination();
  }

  function renderList(todos: unknown[]) {
    const list = document.getElementById('todo-list')!;
    if (!Array.isArray(todos) || todos.length === 0) {
      const msg = !Array.isArray(todos) ? 'No se puede conectar con yrest' : 'No hay tareas';
      list.innerHTML = `<li class="todo-placeholder">${msg}</li>`;
      return;
    }
    list.innerHTML = todos.map((t: any) => {
      const user   = users.get(t.userId);
      const avatar = esc(user?.avatar ?? String(t.userId));
      const name   = esc(user?.name   ?? `User ${t.userId}`);
      const prio   = t.priority ?? 'low';
      return `
        <li class="todo-item ${t.done ? 'is-done' : ''}" data-id="${t.id}" data-done="${t.done}">
          <button class="check-btn" data-action="toggle" title="${t.done ? 'Marcar pendiente' : 'Completar'}">
            ${t.done ? '&#10003;' : ''}
          </button>
          <span class="todo-title">${esc(t.title)}</span>
          <span class="priority-badge ${prio}">${prio}</span>
          <span class="user-avatar" title="${name}">${avatar}</span>
          <button class="delete-btn" data-action="delete" title="Eliminar">&times;</button>
        </li>
      `;
    }).join('');
  }

  function renderPagination() {
    const totalPages = Math.ceil(state.total / state.limit) || 1;
    document.getElementById('page-info')!.textContent = `${state.page} / ${totalPages}`;
    document.getElementById('page-count')!.textContent = `${state.total} tarea${state.total !== 1 ? 's' : ''}`;
    (document.getElementById('prev-btn') as HTMLButtonElement).disabled = state.page <= 1;
    (document.getElementById('next-btn') as HTMLButtonElement).disabled = state.page >= totalPages;
  }

  async function mutate(method: string, path: string, body?: unknown) {
    const r = await fetchApi(method, path, body ?? null);
    dispatch(method, r.url, r.status, r.data);
    await loadTodos();
  }

  // Event delegation — avoids global function pollution
  document.getElementById('todo-list')!.addEventListener('click', (e) => {
    const btn  = (e.target as Element).closest('[data-action]') as HTMLElement | null;
    const item = (e.target as Element).closest('.todo-item')    as HTMLElement | null;
    if (!btn || !item) return;
    const id = parseInt(item.dataset.id!);
    if (btn.dataset.action === 'toggle') {
      mutate('PATCH', `/todos/${id}`, { done: item.dataset.done !== 'true' });
    } else if (btn.dataset.action === 'delete') {
      if (state.page > 1 && state.total % state.limit === 1) state.page--;
      mutate('DELETE', `/todos/${id}`);
    }
  });

  document.getElementById('add-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('add-input') as HTMLInputElement;
    const title = input.value.trim();
    if (!title) return;
    input.value = '';
    state.page = 1;
    await mutate('POST', '/todos', {
      title, done: false, priority: 'medium', userId: 1,
      createdAt: new Date().toISOString().slice(0, 10),
    });
  });

  let searchTimer: ReturnType<typeof setTimeout>;
  document.getElementById('search-input')!.addEventListener('input', (e) => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      state.search = (e.target as HTMLInputElement).value.trim();
      state.page = 1;
      loadTodos();
    }, 350);
  });

  document.getElementById('filter-done')!.addEventListener('change', (e) => {
    state.done = (e.target as HTMLSelectElement).value;
    state.page = 1;
    loadTodos();
  });

  document.getElementById('filter-priority')!.addEventListener('change', (e) => {
    state.priority = (e.target as HTMLSelectElement).value;
    state.page = 1;
    loadTodos();
  });

  document.getElementById('sort-select')!.addEventListener('change', (e) => {
    const [sort, order] = (e.target as HTMLSelectElement).value.split('|');
    state.sort = sort;
    state.order = order;
    state.page = 1;
    loadTodos();
  });

  document.getElementById('limit-select')!.addEventListener('change', (e) => {
    state.limit = parseInt((e.target as HTMLSelectElement).value);
    state.page = 1;
    loadTodos();
  });

  document.getElementById('prev-btn')!.addEventListener('click', () => {
    if (state.page > 1) { state.page--; loadTodos(); }
  });

  document.getElementById('next-btn')!.addEventListener('click', () => {
    if (state.page < Math.ceil(state.total / state.limit)) { state.page++; loadTodos(); }
  });

  window.addEventListener('yrest:connected', async () => {
    await loadUsers();
    await loadTodos();
  });
</script>
