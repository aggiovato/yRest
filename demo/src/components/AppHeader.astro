---
---

<header class="app-header">
  <span class="app-logo">y<span>rest</span></span>
  <span class="header-sep">·</span>
  <span class="app-subtitle">todo list demo</span>
  <div class="server-status" id="server-status">
    <span class="status-dot">●</span>
    <span id="status-text">connecting...</span>
  </div>
</header>

<style>
  .app-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .app-logo {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 15px;
    color: var(--text);
  }
  .app-logo span { color: var(--blue); }

  .header-sep { color: var(--border); }

  .app-subtitle { color: var(--muted); font-size: 13px; }

  .server-status {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .server-status.connected { color: var(--green); }
  .server-status.disconnected { color: var(--red); }
</style>

<script>
  async function checkStatus(): Promise<boolean> {
    const statusEl = document.getElementById('server-status')!;
    const textEl   = document.getElementById('status-text')!;
    try {
      const res = await fetch('http://localhost:3070/api/health', {
        signal: AbortSignal.timeout(2000),
      });
      if (res.ok) {
        statusEl.className = 'server-status connected';
        textEl.textContent = 'connected · localhost:3070';
        return true;
      }
    } catch { /* fall through */ }
    statusEl.className = 'server-status disconnected';
    textEl.textContent = 'disconnected — run npm run api';
    return false;
  }

  (async () => {
    const ok = await checkStatus();
    if (ok) window.dispatchEvent(new CustomEvent('yrest:connected'));

    setInterval(async () => {
      const el = document.getElementById('server-status');
      if (el?.classList.contains('disconnected')) {
        const ok = await checkStatus();
        if (ok) window.dispatchEvent(new CustomEvent('yrest:connected'));
      }
    }, 5000);
  })();
</script>
