{
  "name": "@yrest/cli-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Demo app showcasing every @yrest/cli feature — a todo list backed by a YAML mock API",
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "astro build",
    "preview": "astro preview",
    "api": "yrest serve",
    "start": "concurrently -n \"api,web\" -c \"cyan,magenta\" \"npm run api\" \"npm run dev\""
  },
  "dependencies": {
    "@astrojs/react": "^3.6.3",
    "astro": "^4.16.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@yrest/cli": "file:../",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.0.0"
  }
}
